<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<%- include('partials/head') %>
<body class="bg-dark text-white font-inter antialiased selection:bg-white selection:text-dark overflow-x-hidden">
  <%- include('partials/navbar') %>
  <div id="noise"></div>
  <div id="bg-container"></div>

  <main class="pt-32 pb-20 min-h-screen">
    <div class="mx-auto px-6 lg:px-8" style="max-width:42rem">
      <div class="flex items-center gap-4 mb-6">
        <div class="w-12 h-px bg-white/10"></div>
        <span class="text-xs text-white/30 uppercase tracking-[0.2em] font-medium" data-i18n="nav.list">List</span>
      </div>
      <h1 class="text-4xl font-black text-white tracking-tight mb-4" data-i18n="submit.levelTitle">Submit a Level</h1>
      <p class="text-white/30 text-lg max-w-xl mb-10" data-i18n="submit.levelSub">Fill out the form below to submit a level for review.</p>

      <% if (typeof success !== 'undefined' && success) { %>
        <div class="rounded-2xl bg-white/[0.03] border border-white/10 p-8 text-center">
          <svg class="w-12 h-12 text-white/40 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <h2 class="text-xl font-bold text-white mb-2" data-i18n="submit.levelSuccess">Submission sent!</h2>
          <p class="text-white/40 text-sm mb-6" data-i18n="submit.levelSuccessDesc">Your submission is now pending review by moderators.</p>
          <a href="/submit/level" class="text-sm text-white/60 hover:text-white transition-colors" data-i18n="submit.submitAnother">Submit another</a>
        </div>
      <% } else { %>
        <% if (error) { %>
          <div class="mb-6 p-4 rounded-xl bg-red-500/5 border border-red-500/10 text-red-300 text-sm"><%= error %></div>
        <% } %>
        <form action="/submit/level" method="POST" class="rounded-3xl bg-white/[0.015] border border-white/[0.06] backdrop-blur-2xl p-8" style="display:flex;flex-direction:column;gap:1.5rem">
          <div>
            <label class="block text-xs text-white/30 uppercase tracking-wider mb-2" data-i18n="submit.nameLabel">Level name</label>
            <input type="text" name="name" required maxlength="100"
              class="w-full h-12 px-4 rounded-xl bg-white/5 border border-white/10 text-white text-sm placeholder:text-white/20 focus:outline-none focus:border-white/20 focus:bg-white/[0.03] transition-all duration-300"
              placeholder="e.g. Bloodbath" data-i18n-placeholder="submit.namePlaceholder">
          </div>
          <div>
            <label class="block text-xs text-white/30 uppercase tracking-wider mb-2" data-i18n="submit.creatorsLabel">Creator nickname(s)</label>
            <input type="text" name="creators" required
              class="w-full h-12 px-4 rounded-xl bg-white/5 border border-white/10 text-white text-sm placeholder:text-white/20 focus:outline-none focus:border-white/20 focus:bg-white/[0.03] transition-all duration-300"
              placeholder="Creator1, Creator2" data-i18n-placeholder="submit.creatorsPlaceholder">
          </div>
          <div>
            <label class="block text-xs text-white/30 uppercase tracking-wider mb-2" data-i18n="submit.verifierLabel">Verifier nickname</label>
            <input type="text" name="verifier"
              class="w-full h-12 px-4 rounded-xl bg-white/5 border border-white/10 text-white text-sm placeholder:text-white/20 focus:outline-none focus:border-white/20 focus:bg-white/[0.03] transition-all duration-300"
              placeholder="Verifier" data-i18n-placeholder="submit.verifierPlaceholder">
          </div>
          <div>
            <label class="block text-xs text-white/30 uppercase tracking-wider mb-2" data-i18n="submit.videoLabel">Completion video link</label>
            <input type="url" name="video_url" required
              class="w-full h-12 px-4 rounded-xl bg-white/5 border border-white/10 text-white text-sm placeholder:text-white/20 focus:outline-none focus:border-white/20 focus:bg-white/[0.03] transition-all duration-300"
              placeholder="https://youtube.com/watch?v=..." data-i18n-placeholder="submit.videoPlaceholder">
          </div>
          <div>
            <label class="block text-xs text-white/30 uppercase tracking-wider mb-2" data-i18n="submit.difficultyLabel">Approximate difficulty</label>
            <select name="difficulty" required
              class="w-full h-12 px-4 rounded-xl bg-white/5 border border-white/10 text-white text-sm focus:outline-none focus:border-white/20 focus:bg-white/[0.03] transition-all duration-300 appearance-none">
              <option value="" class="bg-dark text-white/40" data-i18n="submit.difficultyDefault">Select difficulty</option>
              <option value="Easy" class="bg-dark">Easy</option>
              <option value="Medium" class="bg-dark">Medium</option>
              <option value="Hard" class="bg-dark">Hard</option>
              <option value="Insane" class="bg-dark">Insane</option>
              <option value="Extreme" class="bg-dark">Extreme</option>
            </select>
          </div>
          <div>
            <label class="block text-xs text-white/30 uppercase tracking-wider mb-2" data-i18n="submit.bannerLabel">Banner image URL <span class="text-white/20">(optional)</span></label>
            <input type="url" name="banner_url"
              class="w-full h-12 px-4 rounded-xl bg-white/5 border border-white/10 text-white text-sm placeholder:text-white/20 focus:outline-none focus:border-white/20 focus:bg-white/[0.03] transition-all duration-300"
              placeholder="https://imgur.com/your-banner.jpg" data-i18n-placeholder="submit.bannerPlaceholder">
          </div>
          <div>
            <label class="block text-xs text-white/30 uppercase tracking-wider mb-2" data-i18n="submit.commentLabel">Comment <span class="text-white/20">(optional)</span></label>
            <textarea name="comment" rows="3"
              class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white text-sm placeholder:text-white/20 focus:outline-none focus:border-white/20 focus:bg-white/[0.03] transition-all duration-300" style="resize:none"
              placeholder="Any additional info..." data-i18n-placeholder="submit.commentPlaceholder"></textarea>
          </div>
          <button type="submit"
            class="w-full h-12 rounded-xl bg-white text-dark font-semibold text-sm hover:bg-white/90 transition-all duration-300" data-i18n="submit.send">
            Send
          </button>
        </form>
      <% } %>
    </div>
  </main>

<%- include('partials/footer') %>
<%- include('partials/scripts') %>
</body>
</html>
