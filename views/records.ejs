<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<%- include('partials/head') %>
<body class="bg-dark text-white font-inter antialiased selection:bg-white selection:text-dark overflow-x-hidden">
  <%- include('partials/navbar') %>
  <div id="noise"></div>
  <div id="bg-container"></div>

  <main class="pt-32 pb-20 min-h-screen">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-4 mb-6">
        <div class="w-12 h-px bg-white/10"></div>
        <span class="text-xs text-white/30 uppercase tracking-[0.2em] font-medium" data-i18n="records.kicker">Records</span>
      </div>

      <h1 class="text-5xl font-black text-white tracking-tight mb-4">
        <span data-i18n="records.title1">Player</span> <span class="text-white/20" data-i18n="records.title2">Records</span>
      </h1>

      <p class="text-white/30 text-lg max-w-xl mb-12" data-i18n="records.sub">
        Verified completions and progress submitted by the community.
      </p>

      <div class="rounded-3xl bg-white/[0.015] border border-white/[0.06] backdrop-blur-2xl overflow-hidden">
        <div class="grid grid-cols-12 gap-4 px-6 py-4 border-b border-white/[0.04] text-xs text-white/30 uppercase tracking-wider font-medium">
          <div class="col-span-3" data-i18n="records.colPlayer">Player</div>
          <div class="col-span-4" data-i18n="records.colDemon">Demon</div>
          <div class="col-span-2" data-i18n="records.colProgress">Progress</div>
          <div class="col-span-2" data-i18n="records.colStatus">Status</div>
          <div class="col-span-1 text-right" data-i18n="records.colDate">Date</div>
        </div>

        <% if (records.length === 0) { %>
          <div class="flex flex-col items-center justify-center py-24 px-6">
            <div class="w-16 h-16 rounded-2xl bg-white/5 flex items-center justify-center mb-6">
              <svg class="w-8 h-8 text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white/40 mb-2" data-i18n="records.emptyTitle">No records yet</h3>
            <p class="text-sm text-white/20 text-center max-w-md" data-i18n="records.emptySub">
              Player records will appear here once they are submitted and verified.
            </p>
          </div>
        <% } else { %>
          <% records.forEach(function (r) { %>
            <%
              var statusClass = {
                'verified': 'border-white text-white',
                'pending': 'border-white/30 text-white/40',
                'rejected': 'border-white/20 text-white/20 line-through'
              };
              var sc = statusClass[r.status] || 'border-white/40 text-white/60';
              var statusKey = 'records.status' + r.status.charAt(0).toUpperCase() + r.status.slice(1);
            %>
            <div class="group grid grid-cols-12 gap-4 px-6 py-5 border-b border-white/[0.03] last:border-0 hover:bg-white/[0.025] transition-colors duration-300 items-center">
              <div class="col-span-3 flex items-center gap-3">
                <div class="w-7 h-7 rounded-md bg-white/10 flex items-center justify-center text-[11px] font-bold text-white/60">
                  <%= r.username.charAt(0).toUpperCase() %>
                </div>
                <span class="text-sm font-medium text-white"><%= r.username %></span>
              </div>
              <div class="col-span-4">
                <span class="text-white"><%= r.demon_name %></span>
                <span class="ml-2 text-[11px] uppercase tracking-wider text-white/30"><%= r.difficulty %></span>
              </div>
              <div class="col-span-2 text-white/70 text-sm"><%= r.progress %>%</div>
              <div class="col-span-2">
                <span class="inline-flex px-2.5 py-0.5 rounded-full border text-[11px] uppercase tracking-wider <%= sc %>" data-i18n="<%= statusKey %>"><%= r.status %></span>
              </div>
              <div class="col-span-1 text-right text-white/30 text-xs"><%= r.created_at.substring(0, 10) %></div>
            </div>
          <% }); %>
        <% } %>
      </div>

      <% if (records.length > 0) { %>
        <p class="text-center text-white/20 text-sm mt-8"><%= records.length %> record<%= records.length === 1 ? '' : 's' %> listed</p>
      <% } %>
    </div>
  </main>

<%- include('partials/footer') %>
<%- include('partials/scripts') %>
</body>
</html>
