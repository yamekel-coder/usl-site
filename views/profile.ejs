<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<%- include('partials/head') %>
<body class="bg-dark text-white font-inter antialiased selection:bg-white selection:text-dark overflow-x-hidden">
  <%- include('partials/navbar') %>
  <div id="noise"></div>
  <div id="bg-container"></div>

  <main class="pt-32 pb-20 min-h-screen">
    <div class="max-w-3xl mx-auto px-6 lg:px-8">
      <div class="flex items-center gap-4 mb-6">
        <div class="w-12 h-px bg-white/10"></div>
        <span class="text-xs text-white/30 uppercase tracking-[0.2em] font-medium" data-i18n="profile.kicker">Profile</span>
      </div>

      <div class="rounded-3xl bg-white/[0.015] border border-white/[0.06] backdrop-blur-2xl p-8 mb-6 text-center">
        <!-- Avatar above name -->
        <% if (user && user.id === profile.id) { %>
          <form action="/profile/avatar" method="POST" enctype="multipart/form-data" class="group relative mx-auto mb-6" style="width:128px;height:128px">
            <label class="block cursor-pointer" style="width:128px;height:128px">
              <div class="bg-white/5 border border-white/10 flex items-center justify-center overflow-hidden" style="width:128px;height:128px;border-radius:9999px">
                <% if (profile.avatarUrl) { %>
                  <img src="<%= profile.avatarUrl %>?<%= Date.now() %>" class="object-cover" style="width:128px;height:128px" alt="avatar">
                <% } else { %>
                  <span class="text-6xl font-black text-white/20"><%= profile.username.charAt(0).toUpperCase() %></span>
                <% } %>
              </div>
              <div class="absolute inset-0 flex flex-col items-center justify-center cursor-pointer opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="border-radius:9999px;background-color:rgba(0,0,0,0.6)">
                <svg class="w-6 h-6 text-white/80 mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0zM18.75 10.5h.008v.008h-.008V10.5z" />
                </svg>
                <span class="text-[11px] uppercase tracking-wider text-white/80" data-i18n="profile.changeAvatar">Change</span>
              </div>
              <input type="file" name="avatar" accept="image/png,image/jpeg,image/gif,image/webp" class="hidden" onchange="this.closest('form').submit()">
            </label>
          </form>
        <% } else { %>
          <div class="bg-white/5 border border-white/10 flex items-center justify-center overflow-hidden mx-auto mb-6" style="width:128px;height:128px;border-radius:9999px">
            <% if (profile.avatarUrl) { %>
              <img src="<%= profile.avatarUrl %>?<%= Date.now() %>" class="object-cover" style="width:128px;height:128px" alt="avatar">
            <% } else { %>
              <span class="text-6xl font-black text-white/20"><%= profile.username.charAt(0).toUpperCase() %></span>
            <% } %>
          </div>
        <% } %>

        <div class="flex items-center justify-center gap-3 flex-wrap">
          <h2 class="text-3xl font-bold text-white"><%= profile.username %></h2>
          <%
            var roleClass = {
              'admin': 'border-white text-white',
              'moderator': 'border-white/70 text-white/85',
              'user': 'border-white/30 text-white/40'
            };
            var rc = roleClass[profile.role] || 'border-white/30 text-white/40';
            var roleKey = 'profile.role' + profile.role.charAt(0).toUpperCase() + profile.role.slice(1);
          %>
          <span class="inline-flex px-2.5 py-0.5 rounded-full border text-[11px] uppercase tracking-wider <%= rc %>" data-i18n="<%= roleKey %>"><%= profile.role %></span>
        </div>

        <div class="mt-3">
          <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full border border-white/20 text-white/50 text-[11px] uppercase tracking-wider">ID #<%= profile.id %></span>
        </div>

        <div class="mt-4 flex flex-col gap-2 text-sm text-white/40 items-center">
          <span><span class="text-white/25" data-i18n="profile.joined">Joined</span> <%= new Date(profile.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
          <% if (profile.country) { %>
            <span><span class="text-white/25" data-i18n="profile.country">Country</span> <%= flag(profile.country) %> <span class="text-white/40"><%= countryName(profile.country) %></span></span>
          <% } %>
          <% if (user && user.id === profile.id) { %>
            <span class="truncate"><span class="text-white/25" data-i18n="profile.email">Email</span> <%= profile.email %></span>
          <% } %>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-4 mt-8">
          <div class="p-4 rounded-2xl bg-white/[0.02] border border-white/[0.06] text-center">
            <div class="text-3xl font-black text-white"><%= rating %></div>
            <div class="text-xs text-white/30 uppercase tracking-wider mt-1" data-i18n="profile.rating">Rating</div>
          </div>
          <div class="p-4 rounded-2xl bg-white/[0.02] border border-white/[0.06] text-center">
            <div class="text-2xl font-black text-white truncate"><%= profile.country ? flag(profile.country) : '—' %></div>
            <div class="text-xs text-white/30 uppercase tracking-wider mt-1" data-i18n="profile.country">Country</div>
          </div>
          <div class="p-4 rounded-2xl bg-white/[0.02] border border-white/[0.06] text-center">
            <div class="text-3xl font-black text-white">#<%= profile.id %></div>
            <div class="text-xs text-white/30 uppercase tracking-wider mt-1" data-i18n="profile.id">ID</div>
          </div>
        </div>
      </div>

      <!-- Recent records -->
      <div class="rounded-3xl bg-white/[0.015] border border-white/[0.06] backdrop-blur-2xl overflow-hidden mb-6">
        <div class="px-6 py-4 border-b border-white/[0.04] text-sm font-medium text-white/70" data-i18n="profile.recentTitle">Recent Records</div>
        <% if (records.length === 0) { %>
          <div class="px-6 py-10 text-center text-sm text-white/20" data-i18n="profile.noRecords">No records submitted yet.</div>
        <% } else { %>
          <% records.forEach(function (r) { %>
            <%
              var stClass = {
                'verified': 'border-white text-white',
                'pending': 'border-white/30 text-white/40',
                'rejected': 'border-white/20 text-white/20 line-through'
              };
              var sc = stClass[r.status] || 'border-white/40 text-white/60';
              var stKey = 'records.status' + r.status.charAt(0).toUpperCase() + r.status.slice(1);
            %>
            <div class="flex items-center justify-between gap-4 px-6 py-4 border-b border-white/[0.03] last:border-0">
              <div class="min-w-0">
                <div class="text-white truncate"><%= r.demon_name %></div>
                <div class="text-[11px] uppercase tracking-wider text-white/30"><%= r.difficulty %></div>
              </div>
              <div class="text-white/70 text-sm shrink-0"><%= r.progress %>%</div>
              <div class="shrink-0">
                <span class="inline-flex px-2.5 py-0.5 rounded-full border text-[11px] uppercase tracking-wider <%= sc %>" data-i18n="<%= stKey %>"><%= r.status %></span>
              </div>
              <div class="text-white/30 text-xs shrink-0 hidden sm:block"><%= r.created_at.substring(0, 10) %></div>
            </div>
          <% }); %>
        <% } %>
      </div>

      <!-- My submissions -->
      <% if (user && user.id === profile.id) { %>
      <div class="rounded-3xl bg-white/[0.015] border border-white/[0.06] backdrop-blur-2xl overflow-hidden mb-6">
        <div class="px-6 py-4 border-b border-white/[0.04] text-sm font-medium text-white/70" data-i18n="profile.mySubmissions">My Submissions</div>
        <% if (!my_submissions || my_submissions.length === 0) { %>
          <div class="px-6 py-10 text-center text-sm text-white/20" data-i18n="profile.noSubmissions">No submissions yet.</div>
        <% } else { %>
          <% my_submissions.forEach(function (s) { %>
            <%
              var sd = {};
              try { sd = JSON.parse(s.data || '{}'); } catch (e) {}
              var sdClass = {
                'pending': 'border-white/30 text-white/40',
                'approved': 'border-white text-white',
                'rejected': 'border-white/20 text-white/20'
              };
              var ssc = sdClass[s.status] || 'border-white/40 text-white/60';
              var title = s.type === 'moderator' ? 'Moderator application' : (sd.name || 'Level request');
            %>
            <div class="px-6 py-4 border-b border-white/[0.03] last:border-0">
              <div class="flex items-center justify-between gap-4">
                <div class="min-w-0">
                  <div class="text-white truncate"><%= title %></div>
                  <div class="text-[11px] uppercase tracking-wider text-white/30"><%= s.type %></div>
                </div>
                <span class="inline-flex px-2.5 py-0.5 rounded-full border text-[11px] uppercase tracking-wider <%= ssc %>"><%= s.status %></span>
              </div>
              <% if (s.status === 'rejected' && s.reject_reason) { %>
                <div class="mt-2 rounded-lg bg-red-500/5 border border-red-500/15 px-3 py-2 text-xs text-red-300/90">
                  <span class="text-white/40" data-i18n="profile.rejectReason">Reason:</span> <%= s.reject_reason %>
                </div>
              <% } %>
            </div>
          <% }); %>
        <% } %>
      </div>
      <% } %>

      <!-- Avatar upload hint (own profile only) -->
      <% if (user && user.id === profile.id) { %>
        <p class="text-center text-xs text-white/25 mb-6" data-i18n="profile.uploadHint">Hover the avatar to change it · PNG, JPG, GIF or WebP</p>
      <% } %>

      <!-- Settings (own profile only) -->
      <% if (user && user.id === profile.id) { %>
        <% if (success) { %>
          <div class="rounded-2xl border px-5 py-3 mb-6 text-sm
            <%= success === 'country-updated' || success === 'password-updated' ? 'border-green-500/30 bg-green-500/10 text-green-300' : 'border-red-500/30 bg-red-500/10 text-red-300' %>"
            style="border-color:<%= success === 'country-updated' || success === 'password-updated' ? 'rgba(34,197,94,0.3)' : 'rgba(239,68,68,0.3)' %>;background:<%= success === 'country-updated' || success === 'password-updated' ? 'rgba(34,197,94,0.1)' : 'rgba(239,68,68,0.1)' %>">
            <% if (success === 'country-updated') { %>Region updated.<% } %>
            <% if (success === 'password-updated') { %>Password changed.<% } %>
            <% if (success === 'wrong-password') { %>Current password is incorrect.<% } %>
            <% if (success === 'password-short') { %>New password must be at least 6 characters.<% } %>
            <% if (success === 'password-mismatch') { %>New passwords do not match.<% } %>
            <% if (success === 'invalid-country') { %>Invalid region selected.<% } %>
            <% if (success === 'username-updated') { %>Nickname updated.<% } %>
            <% if (success === 'username-short') { %>Nickname must be 3–24 characters.<% } %>
            <% if (success === 'username-invalid') { %>Only letters, numbers, spaces, . _ - are allowed.<% } %>
            <% if (success === 'username-taken') { %>This nickname is already taken.<% } %>
          </div>
        <% } %>

        <% if (user && user.id === profile.id) { %>
          <div class="rounded-3xl bg-white/[0.015] border border-white/[0.06] backdrop-blur-2xl p-6 mb-6">
            <h3 class="text-lg font-bold text-white mb-1" data-i18n="profile.changeUsername">Change Nickname</h3>
            <p class="text-white/40 text-sm mb-5" data-i18n="profile.changeUsernameSub">This is the name shown across the site and leaderboards.</p>
            <form method="POST" action="/profile/username" class="flex flex-col sm:flex-row gap-3">
              <input type="text" name="username" required minlength="3" maxlength="24" value="<%= profile.username %>" placeholder="New nickname" data-i18n-placeholder="profile.newUsername" class="flex-1 h-11 px-4 rounded-xl bg-white/5 border border-white/10 text-white text-sm placeholder:text-white/20 focus:outline-none focus:border-white/20">
              <button type="submit" class="sm:w-44 h-11 rounded-xl bg-white text-dark font-semibold text-sm hover:bg-white/90 transition-all duration-300" data-i18n="profile.saveUsername">Save Nickname</button>
            </form>
          </div>
        <% } %>

        <div class="grid gap-6 md:grid-cols-2 mb-6">
          <!-- Change region -->
          <div class="rounded-3xl bg-white/[0.015] border border-white/[0.06] backdrop-blur-2xl p-6">
            <h3 class="text-lg font-bold text-white mb-1" data-i18n="profile.changeRegion">Change Region</h3>
            <p class="text-white/40 text-sm mb-5" data-i18n="profile.changeRegionSub">Update the country shown on your profile and leaderboards.</p>
            <form method="POST" action="/profile/country" class="space-y-3">
              <div class="usl-select" data-name="country" data-current="<%= profile.country || '' %>" data-options="<%= optAttr(countries) %>"></div>
              <button type="submit" class="w-full h-11 rounded-xl bg-white text-dark font-semibold text-sm hover:bg-white/90 transition-all duration-300" data-i18n="profile.saveRegion">Save Region</button>
            </form>
          </div>

          <!-- Change password -->
          <div class="rounded-3xl bg-white/[0.015] border border-white/[0.06] backdrop-blur-2xl p-6">
            <h3 class="text-lg font-bold text-white mb-1" data-i18n="profile.changePassword">Change Password</h3>
            <p class="text-white/40 text-sm mb-5" data-i18n="profile.changePasswordSub">Enter your current password to set a new one.</p>
            <form method="POST" action="/profile/password" class="space-y-3">
              <input type="password" name="current" required placeholder="Current password" data-i18n-placeholder="profile.currentPassword" class="w-full h-11 px-4 rounded-xl bg-white/5 border border-white/10 text-white text-sm placeholder:text-white/20 focus:outline-none focus:border-white/20">
              <input type="password" name="next" required minlength="6" placeholder="New password" data-i18n-placeholder="profile.newPassword" class="w-full h-11 px-4 rounded-xl bg-white/5 border border-white/10 text-white text-sm placeholder:text-white/20 focus:outline-none focus:border-white/20">
              <input type="password" name="confirm" required minlength="6" placeholder="Confirm new password" data-i18n-placeholder="profile.confirmPassword" class="w-full h-11 px-4 rounded-xl bg-white/5 border border-white/10 text-white text-sm placeholder:text-white/20 focus:outline-none focus:border-white/20">
              <button type="submit" class="w-full h-11 rounded-xl bg-white text-dark font-semibold text-sm hover:bg-white/90 transition-all duration-300" data-i18n="profile.savePassword">Change Password</button>
            </form>
          </div>
        </div>
      <% } %>

      <div class="text-center mt-8">
        <a href="/" class="text-sm text-white/30 hover:text-white transition-colors duration-300" data-i18n="profile.back">← Back to Home</a>
      </div>
    </div>
  </main>

<%- include('partials/footer') %>
<%- include('partials/scripts') %>
<script src="/js/custom-select.js"></script>
</body>
</html>
