<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign In — USL</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-dark text-white font-inter antialiased selection:bg-white selection:text-dark overflow-x-hidden">
  <div id="noise"></div>
  <div id="bg-container"></div>

  <nav class="fixed top-0 left-0 right-0 z-50" style="background: rgba(10,10,10,0.8); backdrop-filter: blur(32px); border-bottom: 1px solid rgba(255,255,255,0.04);">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center justify-between h-20">
        <a href="/" class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-lg bg-white/10 backdrop-blur-xl border border-white/10 flex items-center justify-center overflow-hidden">
            <img src="/uploads/site-logo.png" onerror="this.style.display='none'" class="w-full h-full object-cover" alt="USL">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <span class="text-lg font-bold tracking-tight text-white">USL</span>
        </a>
      </div>
    </div>
  </nav>

  <main class="min-h-screen flex items-center justify-center pt-20 pb-20">
    <div class="w-full max-w-md mx-auto px-6">
      <div class="text-center mb-10">
        <h1 class="text-4xl font-black text-white tracking-tight">Welcome Back</h1>
        <p class="mt-3 text-white/30">Sign in to your USL account</p>
      </div>

      <div class="rounded-3xl bg-white/[0.015] border border-white/[0.06] backdrop-blur-2xl p-8">
        <% if (error) { %>
          <div class="mb-6 p-4 rounded-xl bg-red-500/5 border border-red-500/10 text-red-300 text-sm"><%= error %></div>
        <% } %>

        <form action="/auth/login" method="POST" class="space-y-5">
          <div>
            <label class="block text-xs text-white/30 uppercase tracking-wider mb-2">Email</label>
            <input type="email" name="email" required
              class="w-full h-12 px-4 rounded-xl bg-white/5 border border-white/10 text-white text-sm placeholder:text-white/20 focus:outline-none focus:border-white/20 focus:bg-white/[0.03] transition-all duration-300"
              placeholder="Enter email">
          </div>
          <div>
            <label class="block text-xs text-white/30 uppercase tracking-wider mb-2">Password</label>
            <input type="password" name="password" required
              class="w-full h-12 px-4 rounded-xl bg-white/5 border border-white/10 text-white text-sm placeholder:text-white/20 focus:outline-none focus:border-white/20 focus:bg-white/[0.03] transition-all duration-300"
              placeholder="Enter password">
          </div>
          <button type="submit"
            class="w-full h-12 rounded-xl bg-white text-dark font-semibold text-sm hover:bg-white/90 transition-all duration-300">
            Sign In
          </button>
        </form>

        <div class="mt-6 text-center">
          <span class="text-sm text-white/20">Don't have an account?</span>
          <a href="/auth/register" class="text-sm text-white/50 hover:text-white ml-1 transition-colors duration-300">Create one</a>
        </div>
      </div>
    </div>
  </main>

  <div id="scroll-progress"></div>
  <script src="/js/navbar.js"></script>
  <script src="/js/background.js"></script>
</body>
</html>
