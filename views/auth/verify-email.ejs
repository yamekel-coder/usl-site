<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Confirm Email — USL</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-dark text-white font-inter antialiased min-h-screen flex items-center justify-center p-6">
  <div class="w-full max-w-md rounded-2xl bg-white/[0.02] border border-white/10 p-8 text-center" style="background:rgba(255,255,255,0.02);border-color:rgba(255,255,255,0.1)">
    <div class="w-12 h-12 mx-auto rounded-xl bg-white/10 flex items-center justify-center mb-4">
      <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
    </div>
    <h1 class="text-xl font-bold text-white mb-1">Confirm your email</h1>
    <p class="text-white/40 text-sm mb-6">
      We sent a 6-digit code to <span class="text-white/70"><%= email || 'your email' %></span>.
    </p>

    <% if (success) { %>
      <div class="rounded-xl border border-green-500/30 bg-green-500/10 text-green-300 text-sm px-4 py-3 mb-4" style="border-color:rgba(34,197,94,0.3);background:rgba(34,197,94,0.1)">
        <% if (resent) { %>A new code has been sent.<% } else { %>Email confirmed! You can now use your account.<% } %>
      </div>
    <% } %>
    <% if (error) { %>
      <div class="rounded-xl border border-red-500/30 bg-red-500/10 text-red-300 text-sm px-4 py-3 mb-4" style="border-color:rgba(239,68,68,0.3);background:rgba(239,68,68,0.1)"><%= error %></div>
    <% } %>
    <% if (devcode) { %>
      <div class="rounded-xl border border-yellow-500/40 bg-yellow-500/10 text-yellow-200 text-sm px-4 py-3 mb-4" style="border-color:rgba(250,204,21,0.4);background:rgba(250,204,21,0.1)">
        <div class="font-semibold mb-1">Email delivery unavailable</div>
        <div class="text-white/70">Use this code to verify (copy from server log if shown):</div>
        <div class="text-2xl font-bold tracking-[0.3em] mt-1"><%= devcode %></div>
      </div>
    <% } %>

    <form method="POST" action="/auth/verify-email" class="space-y-3">
      <input type="hidden" name="email" value="<%= email %>">
      <input type="text" name="code" required inputmode="numeric" autocomplete="one-time-code" placeholder="123456"
        class="w-full h-12 px-4 rounded-xl bg-white/5 border border-white/10 text-white text-center text-lg tracking-[0.4em] placeholder:text-white/20 focus:outline-none focus:border-white/20 transition-all">
      <button type="submit" class="w-full h-11 rounded-xl bg-white text-dark text-sm font-semibold hover:bg-white/90 transition-all">Verify</button>
    </form>

    <form method="POST" action="/auth/verify-email/resend" class="mt-4">
      <input type="hidden" name="email" value="<%= email %>">
      <button type="submit" class="text-white/40 hover:text-white text-xs underline">Resend code</button>
    </form>

    <a href="/" class="block mt-6 text-white/30 hover:text-white/60 text-xs">Back to home</a>
  </div>
</body>
</html>
