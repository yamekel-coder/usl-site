<section class="py-16">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center gap-4 mb-8">
      <div class="w-12 h-px bg-white/10"></div>
      <span class="text-xs text-white/30 uppercase tracking-[0.2em] font-medium" data-i18n="news.kicker">News</span>
    </div>
    <h2 class="text-4xl font-black text-white tracking-tight mb-8">
      <span data-i18n="news.title1">Latest</span> <span class="text-white/20" data-i18n="news.title2">Updates</span>
    </h2>

    <% if (!news || news.length === 0) { %>
      <div class="rounded-3xl border border-white/10 p-10 text-center text-sm text-white/30" style="background:rgba(255,255,255,0.02)" data-i18n="news.empty">No news yet.</div>
    <% } else { %>
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        <% news.forEach(function (n) { %>
          <article class="rounded-3xl border border-white/10 p-6 flex flex-col" style="background:rgba(255,255,255,0.02)">
            <div class="text-[11px] text-white/30 uppercase tracking-wider mb-3"><%= n.created_at.substring(0, 10) %><% if (n.author) { %> · <%= n.author %><% } %></div>
            <h3 class="text-lg font-bold text-white mb-2"><%= n.title %></h3>
            <p class="text-sm text-white/50 leading-relaxed flex-1"><%= n.description %></p>
          </article>
        <% }); %>
      </div>
    <% } %>
  </div>
</section>
