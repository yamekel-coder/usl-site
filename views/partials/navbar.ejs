        <div>
          <span class="text-lg font-bold tracking-tight text-white">USL</span>
          <span class="hidden sm:inline text-lg font-bold tracking-tight text-white/40">— Ultimate Shitty List</span>
        </div>
      </a>

      <div class="hidden lg:flex items-center gap-1">
        <a href="/" class="nav-link<%= path === '/' ? ' active' : '' %>" data-i18n="nav.home">Home</a>
        <a href="/list" class="nav-link<%= path === '/list' ? ' active' : '' %>" data-i18n="nav.list">List</a>
        <a href="/records" class="nav-link<%= path === '/records' ? ' active' : '' %>" data-i18n="nav.records">Records</a>
        <a href="/players" class="nav-link<%= path === '/players' ? ' active' : '' %>" data-i18n="nav.players">Players</a>
        <a href="/countries" class="nav-link<%= path === '/countries' ? ' active' : '' %>" data-i18n="nav.countries">Countries</a>
      </div>

      <div class="flex items-center gap-3">
        <button id="lang-toggle" class="w-9 h-9 rounded-lg flex items-center justify-center text-xs font-semibold text-white/40 hover:text-white hover:bg-white/5 transition-all duration-300 tracking-wider uppercase">
          RU
        </button>

        <!-- Mobile hamburger -->
        <button id="mobile-menu-toggle" type="button" class="lg:hidden w-9 h-9 rounded-lg flex items-center justify-center text-white/40 hover:text-white hover:bg-white/5 transition-all duration-300" aria-label="Menu">
          <svg id="hamburger-icon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5"/>
          </svg>
          <svg id="close-icon" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>

        <% if (user) { %>
          <div class="relative group">
            <div class="flex items-center gap-2 px-3 h-9 rounded-lg bg-white/5 hover:bg-white/10 transition-all duration-300 cursor-pointer">
              <div class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center overflow-hidden border border-white/10">
                <% if (user.avatar_url) { %>
                  <img src="<%= user.avatar_url %>" class="w-full h-full object-cover" alt="<%= user.username %>">
                <% } else { %>
                  <span class="text-[11px] font-bold text-white/70"><%= user.username.charAt(0).toUpperCase() %></span>
                <% } %>
              </div>
              <span class="text-sm font-medium text-white/70 hidden sm:inline"><%= user.username %></span>
            </div>
            <div class="absolute right-0 top-full mt-2 w-48 rounded-2xl bg-dark-2/95 backdrop-blur-xl border border-white/10 shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 pointer-events-none group-hover:pointer-events-auto before:absolute before:-top-2 before:left-0 before:right-0 before:h-2 before:content-['']">
              <div class="p-2">
                <div class="px-3 py-2 text-xs text-white/30 border-b border-white/5 mb-1">
                  Signed in as <span class="text-white/60 font-medium"><%= user.username %></span>
                </div>
                <a href="/profile" class="block px-3 py-2 text-sm text-white/50 hover:text-white hover:bg-white/5 rounded-lg transition-all duration-200" data-i18n="nav.profile">Profile</a>
                <% if (user.role === 'admin' || user.role === 'moderator') { %>
                  <a href="/admin" class="block px-3 py-2 text-sm text-white/50 hover:text-white hover:bg-white/5 rounded-lg transition-all duration-200">Admin</a>
                <% } %>
                <a href="/submit/level" class="block px-3 py-2 text-sm text-white/50 hover:text-white hover:bg-white/5 rounded-lg transition-all duration-200" data-i18n="nav.submitLevel">Submit Level</a>
                <a href="/submit/moderator" class="block px-3 py-2 text-sm text-white/50 hover:text-white hover:bg-white/5 rounded-lg transition-all duration-200" data-i18n="nav.applyMod">Apply as Moderator</a>
                <form action="/auth/logout" method="POST">
                  <button type="submit" class="w-full text-left px-3 py-2 text-sm text-red-300/50 hover:text-red-300 hover:bg-white/5 rounded-lg transition-all duration-200">Sign Out</button>
                </form>
              </div>
            </div>
          </div>
        <% } else { %>
          <button type="button" data-auth-open="register" class="hidden sm:inline-flex items-center px-4 h-9 rounded-lg bg-white text-dark text-sm font-semibold hover:bg-white/90 transition-all duration-300" data-i18n="nav.signup">Sign Up</button>
          <button type="button" data-auth-open="login" class="hidden sm:inline-flex items-center px-4 h-9 rounded-lg border border-white/15 text-white/70 text-sm font-medium hover:text-white hover:bg-white/5 transition-all duration-300" data-i18n="nav.signin">Sign In</button>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden hidden" style="background:rgba(5,5,5,0.97);backdrop-filter:blur(12px);border-top:1px solid rgba(255,255,255,0.06)">
    <div class="max-w-7xl mx-auto px-6 py-4 flex flex-col gap-1">
      <a href="/" class="mobile-nav-link<%= path === '/' ? ' active' : '' %>" data-i18n="nav.home">Home</a>
      <a href="/list" class="mobile-nav-link<%= path === '/list' ? ' active' : '' %>" data-i18n="nav.list">List</a>
      <a href="/records" class="mobile-nav-link<%= path === '/records' ? ' active' : '' %>" data-i18n="nav.records">Records</a>
      <a href="/players" class="mobile-nav-link<%= path === '/players' ? ' active' : '' %>" data-i18n="nav.players">Players</a>
      <a href="/countries" class="mobile-nav-link<%= path === '/countries' ? ' active' : '' %>" data-i18n="nav.countries">Countries</a>
      <div class="border-t border-white/5 my-2"></div>
      <% if (user) { %>
        <a href="/profile" class="mobile-nav-link" data-i18n="nav.profile">Profile</a>
        <% if (user.role === 'admin' || user.role === 'moderator') { %>
          <a href="/admin" class="mobile-nav-link">Admin</a>
        <% } %>
        <a href="/submit/level" class="mobile-nav-link" data-i18n="nav.submitLevel">Submit Level</a>
        <a href="/submit/moderator" class="mobile-nav-link" data-i18n="nav.applyMod">Apply as Moderator</a>
        <form action="/auth/logout" method="POST" class="mt-1">
          <button type="submit" class="w-full text-left px-3 py-3 text-sm text-red-300/70 hover:text-red-300 hover:bg-white/5 rounded-xl transition-all duration-200">Sign Out</button>
        </form>
      <% } else { %>
        <div class="flex gap-3 mt-1">
          <button type="button" data-auth-open="register" class="flex-1 h-11 rounded-xl bg-white text-dark text-sm font-semibold hover:bg-white/90 transition-all duration-300" data-i18n="nav.signup">Sign Up</button>
          <button type="button" data-auth-open="login" class="flex-1 h-11 rounded-xl border border-white/15 text-white/70 text-sm font-medium hover:text-white hover:bg-white/5 transition-all duration-300" data-i18n="nav.signin">Sign In</button>
        </div>
      <% } %>
    </div>
  </div>
</nav>

<script>
(function() {
  var toggle = document.getElementById('mobile-menu-toggle');
  var menu = document.getElementById('mobile-menu');
  var hamburger = document.getElementById('hamburger-icon');
  var close = document.getElementById('close-icon');
  if (!toggle || !menu) return;
  toggle.addEventListener('click', function() {
    var open = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden');
    hamburger.classList.toggle('hidden');
    close.classList.toggle('hidden');
  });
  menu.querySelectorAll('a').forEach(function(a) {
    a.addEventListener('click', function() {
      menu.classList.add('hidden');
      hamburger.classList.remove('hidden');
      close.classList.add('hidden');
    });
  });
})();
</script>

<%- include('auth-modal') %>
