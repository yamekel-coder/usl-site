<section id="hero" class="relative min-h-screen flex items-center pt-20">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 w-full">
    <div class="grid lg:grid-cols-5 gap-12 items-center" style="gap:4rem">
      <div class="lg:col-span-3">
        <div id="hero-badge" class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-xs text-white/50 uppercase tracking-widest mb-8 opacity-0">
          <span class="w-1.5 h-1.5 rounded-full bg-white/40 animate-pulse"></span>
          <span data-i18n="hero.badge">Global Demon Ranking</span>
        </div>

        <h1 id="hero-title" class="text-5xl font-black tracking-tight leading-none text-white">
          <span class="block" data-i18n="hero.title1">Ultimate</span>
          <span id="gd-prank-btn" class="block text-white cursor-pointer select-none" data-i18n="hero.title2">Shitty</span>
          <span class="block" data-i18n="hero.title3">List</span>
        </h1>

        <p id="hero-sub" class="mt-6 text-lg sm:text-xl text-white/30 max-w-xl leading-relaxed opacity-0" data-i18n="hero.sub">
          The best ranking of shitty levels in Geometry Dash. It's community-driven, transparent, and constantly evolving.
        </p>

        <div id="hero-cta" class="mt-10 flex flex-wrap gap-4 opacity-0">
          <a href="/list" class="group inline-flex items-center gap-2 px-8 h-12 rounded-xl bg-white text-dark font-semibold text-sm hover:bg-white/90 transition-all duration-300">
            <span data-i18n="hero.cta1">Explore Rankings</span>
            <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a href="/list" class="group inline-flex items-center gap-2 px-8 h-12 rounded-xl bg-white/5 border border-white/10 text-white/80 font-semibold text-sm hover:bg-white/10 hover:border-white/20 transition-all duration-300">
            <span data-i18n="hero.cta2">Submit Record</span>
          </a>
        </div>
      </div>

      <div id="hero-stats" class="lg:col-span-2 grid grid-cols-2 gap-4">
        <div class="stat-card opacity-0 p-6 rounded-2xl bg-white/[0.02] border border-white/[0.06] backdrop-blur-xl">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center">
              <svg class="w-4 h-4 text-white/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
              </svg>
            </div>
            <span class="text-xs text-white/30 uppercase tracking-wider" data-i18n="hero.stat1">Players</span>
          </div>
          <div class="text-3xl font-black text-white">
             <span class="counter" data-target="<%= stats.players %>">0</span><span class="text-white/40">+</span>
          </div>
        </div>

        <div class="stat-card opacity-0 p-6 rounded-2xl bg-white/[0.02] border border-white/[0.06] backdrop-blur-xl">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center">
              <svg class="w-4 h-4 text-white/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
              </svg>
            </div>
            <span class="text-xs text-white/30 uppercase tracking-wider" data-i18n="hero.stat2">Records</span>
          </div>
          <div class="text-3xl font-black text-white">
             <span class="counter" data-target="<%= stats.records %>">0</span><span class="text-white/40">+</span>
          </div>
        </div>

        <div class="stat-card opacity-0 p-6 rounded-2xl bg-white/[0.02] border border-white/[0.06] backdrop-blur-xl">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center">
              <svg class="w-4 h-4 text-white/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 6.878V6a2.25 2.25 0 012.25-2.25h7.5A2.25 2.25 0 0118 6v.878m-12 0c.235-.083.487-.128.75-.128h10.5c.263 0 .515.045.75.128m-12 0A2.25 2.25 0 004.5 9v.75c0 .621.504 1.125 1.125 1.125H6m12-2.25A2.25 2.25 0 0119.5 9v.75c0 .621-.504 1.125-1.125 1.125H18M4.5 18.75V9m0 9.75c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V9M4.5 18.75h15" />
              </svg>
            </div>
            <span class="text-xs text-white/30 uppercase tracking-wider" data-i18n="hero.stat3">Levels</span>
          </div>
          <div class="text-3xl font-black text-white">
             <span class="counter" data-target="<%= stats.levels %>">0</span><span class="text-white/40">+</span>
          </div>
        </div>

        <div class="stat-card opacity-0 p-6 rounded-2xl bg-white/[0.02] border border-white/[0.06] backdrop-blur-xl">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center">
              <svg class="w-4 h-4 text-white/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
              </svg>
            </div>
            <span class="text-xs text-white/30 uppercase tracking-wider" data-i18n="hero.stat4">Countries</span>
          </div>
          <div class="text-3xl font-black text-white">
             <span class="counter" data-target="<%= stats.countries %>">0</span><span class="text-white/40">+</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-dark to-transparent pointer-events-none"></div>
</section>
