<section id="recent" class="relative py-32">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center gap-4 mb-16 reveal">
      <div class="w-12 h-px bg-white/10"></div>
      <span class="text-xs text-white/30 uppercase tracking-[0.2em] font-medium" data-i18n="recent.label">Recent Changes</span>
    </div>

    <div class="grid lg:grid-cols-5 gap-12">
      <div class="lg:col-span-2 reveal">
        <h2 class="text-4xl font-black text-white leading-tight tracking-tight">
          <span data-i18n="recent.title1">Latest</span><br>
          <span class="text-white/20" data-i18n="recent.title2">Updates</span>
        </h2>
        <p class="mt-6 text-white/30 leading-relaxed text-lg" data-i18n="recent.desc">
          Stay up to date with the latest changes to the Ultimate Shitty List. New levels added, positions shifted, and records verified daily.
        </p>
      </div>

      <div class="lg:col-span-3">
        <div class="rounded-3xl bg-white/[0.015] border border-white/[0.06] backdrop-blur-2xl overflow-hidden reveal">
          <% if (news && news.length > 0) { %>
            <div class="divide-y divide-white/[0.04]">
              <% news.slice(0, 4).forEach(function (n) { %>
                <div class="change-item opacity-0 group flex items-start gap-5 p-6 hover:bg-white/[0.02] transition-all duration-300">
                  <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center shrink-0 group-hover:bg-white/10 transition-colors duration-300">
                    <svg class="w-5 h-5 text-white/40 group-hover:text-white/80 transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5" />
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="font-semibold text-white group-hover:text-white/90 transition-colors mb-1"><%= n.title %></div>
                    <p class="text-sm text-white/30 group-hover:text-white/40 transition-colors line-clamp-2"><%= n.description %></p>
                  </div>
                  <span class="text-xs text-white/20 shrink-0"><%= n.created_at ? n.created_at.substring(0, 10) : '' %></span>
                </div>
              <% }); %>
            </div>
          <% } else { %>
            <div class="p-10 text-center text-sm text-white/20" data-i18n="recent.noNews">No recent updates yet.</div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>
